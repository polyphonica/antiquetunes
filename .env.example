SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=YOUR_SERVER_IP
DATABASE_URL=postgres://antiquetunes:PASSWORD@localhost:5432/antiquetunes_staging
DJANGO_SETTINGS_MODULE=antiquetunes.settings.staging

# Stripe — use test keys for staging
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email — use console backend for staging, or Ionos SMTP
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@antiquetunes.com

SITE_URL=http://YOUR_SERVER_IP:8001
MEDIA_ROOT=/var/www/antiquetunes/media
PROTECTED_MEDIA_ROOT=/var/www/antiquetunes/protected_media
