SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=antiquetunes.com,www.antiquetunes.com
DATABASE_URL=postgres://antiquetunes:PASSWORD@localhost:5432/antiquetunes
DJANGO_SETTINGS_MODULE=antiquetunes.settings.production

# Stripe — test keys for development, live keys for production
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.ionos.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@antiquetunes.com
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@antiquetunes.com

SITE_URL=https://www.antiquetunes.com
MEDIA_ROOT=/var/www/antiquetunes/media
PROTECTED_MEDIA_ROOT=/var/www/antiquetunes/protected_media
